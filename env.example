# Hologres (PostgreSQL) – copy to .env.local and fill in values
# Option A: Separate vars
# HOLOGRES_HOST=hgpre-sg-e1n479ytg002-cn-hongkong.hologres.aliyuncs.com
# HOLOGRES_PORT=8099
# HOLOGRES_USER=BASIC$marketing
# HOLOGRES_PASSWORD=your_password
# HOLOGRES_DATABASE=ads

# Option B: Full URI (use if you get EAI_AGAIN – paste the Public Endpoint from Hologres console)
# HOLOGRES_URI=postgresql://USER:PASSWORD@HOST:PORT/DATABASE?sslmode=require

# If you get getaddrinfo EAI_AGAIN: DNS can't resolve the host from this network.
# Try: (1) Run from Alibaba Cloud ECS in same region  (2) Use VPN  (3) Set NODE_OPTIONS=--dns-result-order=ipv4first

# Demo sign-in (client-side; NEXT_PUBLIC_ exposes to browser)
# NEXT_PUBLIC_AUTH_EMAIL=admin@gtcfx.com
# NEXT_PUBLIC_AUTH_PASSWORD=gtcfx@123
